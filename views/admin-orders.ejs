<%- include('partials/header') %><h2>Quản lý đơn hàng COD</h2><div class="table-wrap"><table><tr><th>ID</th><th>Khách</th><th>SĐT</th><th>Địa chỉ</th><th>Tổng</th><th>Trạng thái</th><th>Cập nhật</th></tr><% orders.forEach(o => { %><tr><td>#<%= o.id %></td><td><%= o.customer_name %></td><td><%= o.phone %></td><td><%= o.address %></td><td><%= Number(o.total).toLocaleString('vi-VN') %>đ</td><td><%= o.status %></td><td><form method="post" action="/admin/orders/<%= o.id %>/status" class="inline-form"><select name="status"><option value="new">new</option><option value="confirmed">confirmed</option><option value="shipping">shipping</option><option value="done">done</option><option value="cancelled">cancelled</option></select><button class="btn small">Lưu</button></form></td></tr><% }) %></table></div><%- include('partials/footer') %>
