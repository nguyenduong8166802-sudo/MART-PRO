<%- include('partials/header') %><section class="section-head"><h2>Giỏ hàng</h2></section><div class="cart-list"><% if (cart.length === 0) { %><div class="panel">Giỏ hàng đang trống.</div><% } %><% cart.forEach(item => { %><div class="cart-item card"><img src="<%= item.image_url %>" alt=""><div class="cart-info"><h3><%= item.name %></h3><div>Số lượng: <%= item.quantity %></div><div class="price"><%= Number(item.price).toLocaleString('vi-VN') %>đ</div></div><form method="post" action="/cart/remove/<%= item.product_id %>"><button class="btn danger">Xóa</button></form></div><% }) %></div><div class="cart-total panel"><strong>Tổng tiền: <%= Number(total).toLocaleString('vi-VN') %>đ</strong><% if (cart.length > 0) { %><a class="btn primary" href="/checkout">Tiến hành đặt hàng</a><% } %></div><%- include('partials/footer') %>
