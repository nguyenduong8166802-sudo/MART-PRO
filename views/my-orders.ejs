<%- include('partials/header') %><h2>Đơn hàng của tôi</h2><div class="table-wrap"><table><tr><th>Mã đơn</th><th>Loại ship</th><th>Tiền hàng</th><th>Phí ship</th><th>Tổng</th><th>Trạng thái</th></tr><% orders.forEach(o => { %><tr><td>#<%= o.id %></td><td><%= o.shipping_method === 'city' ? 'Nội thành' : 'Toàn quốc' %></td><td><%= money(o.items_total || o.total) %></td><td><%= Number(o.shipping_fee || 0) > 0 ? money(o.shipping_fee) : 'Chờ xác nhận' %></td><td><%= money((o.confirmed_total && o.confirmed_total > 0) ? o.confirmed_total : o.total) %></td><td><%= o.status %></td></tr><% }) %></table></div><%- include('partials/footer') %>
