<%- include('partials/header') %><h2>Đơn hàng của tôi</h2><div class="table-wrap"><table><tr><th>Mã đơn</th><th>Tổng</th><th>Trạng thái</th><th>Ngày tạo</th></tr><% orders.forEach(o => { %><tr><td>#<%= o.id %></td><td><%= Number(o.total).toLocaleString('vi-VN') %>đ</td><td><%= o.status %></td><td><%= new Date(o.created_at).toLocaleString('vi-VN') %></td></tr><% }) %></table></div><%- include('partials/footer') %>
