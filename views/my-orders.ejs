<%- include('partials/header') %>
<h2>Đơn hàng của tôi</h2>
<div class="table-wrap">
<table>
<tr><th>Mã đơn</th><th>Loại ship</th><th>Tiền hàng</th><th>Phí ship</th><th>Tổng</th><th>Trạng thái</th></tr>
<% orders.forEach(o => { %>
<tr>
  <td>#<%= o.id %></td>
  <td><%= o.shipping_method === 'city' ? 'Nội thành' : 'Toàn quốc' %></td>
  <td><%= Number(o.items_total || o.total).toLocaleString('vi-VN') %>đ</td>
  <td><%= o.shipping_fee ? Number(o.shipping_fee).toLocaleString('vi-VN') + 'đ' : 'Chờ xác nhận' %></td>
  <td><%= Number((o.confirmed_total && o.confirmed_total > 0) ? o.confirmed_total : o.total).toLocaleString('vi-VN') %>đ</td>
  <td><%= o.status %></td>
</tr>
<% }) %>
</table>
</div>
<%- include('partials/footer') %>
