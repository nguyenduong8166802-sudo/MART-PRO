<%- include('partials/header') %><h2>Ví seller</h2><section class="dash-grid" style="grid-template-columns:repeat(4,1fr)"><div class="stat-card"><span>Số dư khả dụng</span><strong><%= money(wallet.balance) %></strong></div><div class="stat-card"><span>Đang chờ</span><strong><%= money(wallet.pending_balance) %></strong></div><div class="stat-card"><span>Tổng kiếm được</span><strong><%= money(wallet.total_earned) %></strong></div><div class="stat-card"><span>% commission</span><strong><%= wallet.commission_rate %>%</strong></div></section><div class="panel"><h3>Yêu cầu rút tiền</h3><form method="post" action="/seller/wallet/request-payout" class="form-grid"><input name="amount" placeholder="Số tiền muốn rút"><textarea name="bank_info" placeholder="Ngân hàng / STK / Chủ tài khoản"></textarea><button class="btn primary">Gửi yêu cầu rút</button></form></div><div class="panel"><h3>Lịch sử commission</h3><div class="table-wrap"><table><tr><th>ID</th><th>Order</th><th>Base</th><th>%</th><th>Commission</th><th>Trạng thái</th></tr><% commissions.forEach(c => { %><tr><td><%= c.id %></td><td>#<%= c.order_id %></td><td><%= money(c.base_amount) %></td><td><%= c.commission_rate %>%</td><td><%= money(c.commission_amount) %></td><td><%= c.status %></td></tr><% }) %></table></div></div><div class="panel"><h3>Lịch sử payout</h3><div class="table-wrap"><table><tr><th>ID</th><th>Số tiền</th><th>Thông tin</th><th>Trạng thái</th></tr><% payouts.forEach(p => { %><tr><td><%= p.id %></td><td><%= money(p.amount) %></td><td><%= p.bank_info %></td><td><%= p.status %></td></tr><% }) %></table></div></div><%- include('partials/footer') %>
