<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DUONG MART FOOD</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="top-banner"><%= cms?.top_banner || '' %></div>
  <header class="header">
    <div class="brand">DUONG MART FOOD</div>
    <nav class="nav">
      <a href="/">Trang chủ</a>
      <a href="/cart">Giỏ hàng (<%= (cart || []).length %>)</a>
      <% if (!currentUser) { %>
        <a href="/register">Đăng ký</a>
        <a href="/login">Đăng nhập</a>
      <% } else { %>
        <% if (currentUser.role === 'buyer') { %><a href="/my-orders">Đơn của tôi</a><% } %>
        <% if (currentUser.role === 'seller') { %><a href="/seller/products">Seller</a><% } %>
        <% if (currentUser.role === 'admin') { %>
          <a href="/admin">Admin</a>
          <a href="/admin/products">Sản phẩm</a>
          <a href="/admin/orders">Đơn hàng</a>
          <a href="/admin/cms">CMS</a>
          <a href="/admin/flash-sales">Flash Sale</a>
        <% } %>
        <form action="/logout" method="post" class="logout-form"><button>Đăng xuất</button></form>
      <% } %>
    </nav>
  </header>
  <main class="container">
