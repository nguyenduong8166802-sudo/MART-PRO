<%- include('partials/header') %><h2>Commission / Ví seller</h2><div class="panel"><h3>Ví seller</h3><div class="table-wrap"><table><tr><th>Seller</th><th>Email</th><th>Số dư</th><th>Đang chờ</th><th>Tổng earned</th><th>%</th><th>Action</th></tr><% wallets.forEach(w => { %><tr><td><%= w.name %></td><td><%= w.email %></td><td><%= money(w.balance) %></td><td><%= money(w.pending_balance) %></td><td><%= money(w.total_earned) %></td><td><%= w.commission_rate %>%</td><td><form method="post" action="/admin/commissions/<%= w.seller_id %>/release-pending"><button class="btn primary small">Release pending</button></form></td></tr><% }) %></table></div></div><div class="panel"><h3>Yêu cầu payout</h3><div class="table-wrap"><table><tr><th>ID</th><th>Seller</th><th>Số tiền</th><th>Bank info</th><th>Trạng thái</th><th>Action</th></tr><% payouts.forEach(p => { %><tr><td><%= p.id %></td><td><%= p.name %></td><td><%= money(p.amount) %></td><td><%= p.bank_info %></td><td><%= p.status %></td><td><form method="post" action="/admin/payouts/<%= p.id %>/approve" style="margin-bottom:6px;"><input name="admin_note" placeholder="Ghi chú admin" style="padding:8px;border:1px solid #ececec;border-radius:8px;"><button class="btn primary small">Approve</button></form><form method="post" action="/admin/payouts/<%= p.id %>/reject"><input name="admin_note" placeholder="Ghi chú admin" style="padding:8px;border:1px solid #ececec;border-radius:8px;"><button class="btn danger small">Reject</button></form></td></tr><% }) %></table></div></div><%- include('partials/footer') %>
