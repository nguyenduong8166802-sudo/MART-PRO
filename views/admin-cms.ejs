<%- include('partials/header') %><h2>Marketing / Banner / Hotline</h2><div class="panel"><form method="post" action="/admin/cms" class="form-grid"><input name="top_banner" value="<%= cms.top_banner %>" placeholder="Banner trên cùng"><input name="hero_badge" value="<%= cms.hero_badge %>" placeholder="Badge"><input name="hero_title" value="<%= cms.hero_title %>" placeholder="Tiêu đề lớn"><textarea name="hero_desc" placeholder="Mô tả"><%= cms.hero_desc %></textarea><input name="cta_primary" value="<%= cms.cta_primary %>" placeholder="CTA 1"><input name="cta_secondary" value="<%= cms.cta_secondary %>" placeholder="CTA 2"><input name="hero_image" value="<%= cms.hero_image %>" placeholder="Ảnh hero"><input name="side_title" value="<%= cms.side_title %>" placeholder="Tiêu đề cột phải"><textarea name="side_bullets" placeholder="Mỗi dòng 1 bullet"><%= cms.side_bullets %></textarea><input name="free_ship_note" value="<%= cms.free_ship_note %>" placeholder="Freeship note"><input name="hotline" value="<%= cms.hotline %>" placeholder="Hotline"><input name="zalo_link" value="<%= cms.zalo_link %>" placeholder="Link Zalo"><button class="btn primary">Lưu CMS</button></form></div><div class="panel"><h3>Thêm banner quảng cáo</h3><form method="post" action="/admin/banners" class="form-grid"><input name="title" placeholder="Tiêu đề banner"><input name="image_url" placeholder="Link ảnh"><input name="link_url" placeholder="Link đích"><input name="position" value="home" placeholder="Position"><label><input type="checkbox" name="is_active" checked> Bật</label><button class="btn primary">Thêm banner</button></form></div><div class="table-wrap"><table><tr><th>ID</th><th>Tiêu đề</th><th>Ảnh</th><th>Xóa</th></tr><% banners.forEach(b => { %><tr><td><%= b.id %></td><td><%= b.title %></td><td><a href="<%= b.image_url %>" target="_blank">Xem ảnh</a></td><td><form method="post" action="/admin/banners/<%= b.id %>/delete"><button class="btn danger small">Xóa</button></form></td></tr><% }) %></table></div><%- include('partials/footer') %>
