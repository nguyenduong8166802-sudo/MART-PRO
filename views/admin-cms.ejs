<%- include('partials/header') %>
<h2>One File CMS</h2>
<div class="panel">
  <form method="post" action="/admin/cms" class="form-grid">
    <input name="top_banner" value="<%= cms.top_banner %>" placeholder="Banner trên cùng">
    <input name="hero_badge" value="<%= cms.hero_badge %>" placeholder="Badge">
    <input name="hero_title" value="<%= cms.hero_title %>" placeholder="Tiêu đề lớn">
    <textarea name="hero_desc" placeholder="Mô tả"><%= cms.hero_desc %></textarea>
    <input name="cta_primary" value="<%= cms.cta_primary %>" placeholder="CTA 1">
    <input name="cta_secondary" value="<%= cms.cta_secondary %>" placeholder="CTA 2">
    <input name="hero_image" value="<%= cms.hero_image %>" placeholder="Ảnh hero">
    <input name="side_title" value="<%= cms.side_title %>" placeholder="Tiêu đề cột phải">
    <textarea name="side_bullets" placeholder="Điểm nổi bật, mỗi dòng 1 ý"><%= cms.side_bullets %></textarea>
    <input name="free_ship_note" value="<%= cms.free_ship_note %>" placeholder="Freeship note">
    <input name="hotline" value="<%= cms.hotline %>" placeholder="Hotline">
    <input name="zalo_link" value="<%= cms.zalo_link %>" placeholder="Link Zalo">
    <input name="promo_line_1" value="<%= cms.promo_line_1 %>" placeholder="Dòng quảng cáo 1">
    <input name="promo_line_2" value="<%= cms.promo_line_2 %>" placeholder="Dòng quảng cáo 2">
    <input name="promo_line_3" value="<%= cms.promo_line_3 %>" placeholder="Dòng quảng cáo 3">
    <input name="promo_line_4" value="<%= cms.promo_line_4 %>" placeholder="Dòng quảng cáo 4">
    <input name="section_flash_title" value="<%= cms.section_flash_title %>" placeholder="Tiêu đề Flash Sale">
    <input name="section_combo_title" value="<%= cms.section_combo_title %>" placeholder="Tiêu đề Combo">
    <input name="section_featured_title" value="<%= cms.section_featured_title %>" placeholder="Tiêu đề Món bán chạy">
    <input name="shipping_city_note" value="<%= cms.shipping_city_note %>" placeholder="Ghi chú ship nội thành">
    <input name="shipping_nationwide_note" value="<%= cms.shipping_nationwide_note %>" placeholder="Ghi chú ship toàn quốc">
    <button class="btn primary" style="grid-column:1/-1;">Lưu CMS</button>
  </form>
</div>

<div class="panel">
  <h3>Thêm banner quảng cáo</h3>
  <form method="post" action="/admin/banners" class="form-grid">
    <input name="title" placeholder="Tiêu đề banner">
    <input name="image_url" placeholder="Link ảnh">
    <input name="link_url" placeholder="Link đích">
    <input name="position" value="home" placeholder="Position">
    <label><input type="checkbox" name="is_active" checked> Bật</label>
    <button class="btn primary">Thêm banner</button>
  </form>
</div>

<div class="table-wrap">
<table>
<tr><th>ID</th><th>Tiêu đề</th><th>Ảnh</th><th>Xóa</th></tr>
<% banners.forEach(b => { %>
<tr>
  <td><%= b.id %></td>
  <td><%= b.title %></td>
  <td><a href="<%= b.image_url %>" target="_blank">Xem ảnh</a></td>
  <td><form method="post" action="/admin/banners/<%= b.id %>/delete"><button class="btn danger small">Xóa</button></form></td>
</tr>
<% }) %>
</table>
</div>
<%- include('partials/footer') %>
