<%- include('partials/header') %><section class="hero"><div class="hero-left card"><div class="badge"><%= cms?.hero_badge %></div><h1><%= cms?.hero_title %></h1><p><%= cms?.hero_desc %></p><div class="hero-actions"><a class="btn primary" href="/cart"><%= cms?.cta_primary %></a><a class="btn secondary" href="#flash-sale"><%= cms?.cta_secondary %></a></div></div><div class="hero-right card"><img class="hero-image" src="<%= cms?.hero_image %>" alt=""><h3><%= cms?.side_title %></h3><ul><% (cms?.side_bullets || '').split('\n').forEach(item => { if(item.trim()) { %><li><%= item %></li><% }}) %></ul></div></section><section class="categories-row"><% categories.forEach(c => { %><a href="/category/<%= c.slug %>" class="cat-pill"><%= c.name %></a><% }) %></section><section class="banners-grid"><% banners.forEach(b => { %><a href="<%= b.link_url %>" class="banner-card"><img src="<%= b.image_url %>" alt="<%= b.title %>"><div class="banner-title"><%= b.title %></div></a><% }) %></section><section class="section-head" id="flash-sale"><h2>Flash Sale hôm nay</h2></section><div class="products-grid"><% flashSales.forEach(item => { %><div class="product-card flash"><img src="<%= item.image_url %>" alt=""><div class="product-info"><h3><%= item.name %></h3><div class="old-price"><%= Number(item.original_price).toLocaleString('vi-VN') %>đ</div><div class="price"><%= Number(item.sale_price).toLocaleString('vi-VN') %>đ</div><form method="post" action="/cart/add/<%= item.product_id %>"><button class="btn primary full">Mua ngay</button></form></div></div><% }) %></div><section class="section-head"><h2>Combo gia đình</h2></section><div class="products-grid"><% combos.forEach(p => { %><div class="product-card"><img src="<%= p.image_url %>" alt=""><div class="product-info"><h3><%= p.name %></h3><div class="muted"><%= p.short_desc %></div><div class="price"><%= Number(p.sale_price || p.price).toLocaleString('vi-VN') %>đ</div><form method="post" action="/cart/add/<%= p.id %>"><button class="btn primary full">Thêm vào giỏ</button></form></div></div><% }) %></div><section class="section-head"><h2>Món bán chạy</h2></section><div class="products-grid"><% featured.forEach(p => { %><div class="product-card"><img src="<%= p.image_url %>" alt=""><div class="product-info"><h3><%= p.name %></h3><div class="muted"><%= p.storage_note %></div><div class="price"><%= Number(p.sale_price || p.price).toLocaleString('vi-VN') %>đ</div><form method="post" action="/cart/add/<%= p.id %>"><button class="btn primary full">Thêm vào giỏ</button></form></div></div><% }) %></div><%- include('partials/footer') %>
