<%- include('partials/header') %><section class="hero"><div class="hero-left card"><div class="badge"><%= cms?.hero_badge %></div><h1><%= cms?.hero_title %></h1><p><%= cms?.hero_desc %></p><div class="promo-lines"><% [cms?.promo_line_1,cms?.promo_line_2,cms?.promo_line_3,cms?.promo_line_4].forEach(line => { if(line){ %><div class="promo-line">👉 <%= line %></div><% } }) %></div><div class="ship-choice-row"><div class="ship-card"><strong>🚀 Nội thành</strong><div><%= cms?.shipping_city_note %></div></div><div class="ship-card"><strong>📦 Toàn quốc</strong><div><%= cms?.shipping_nationwide_note %></div></div></div><div class="hero-actions"><a class="btn primary" href="/cart"><%= cms?.cta_primary %></a><a class="btn secondary" href="#flash-sale"><%= cms?.cta_secondary %></a></div></div><div class="hero-right card"><img class="hero-image" src="<%= cms?.hero_image %>" alt=""><h3><%= cms?.side_title %></h3><ul class="feature-list"><% (cms?.side_bullets || '').split('\n').forEach(item => { if(item.trim()){ %><li><%= item %></li><% } }) %></ul></div></section><section class="categories-row"><% categories.forEach(c => { %><a href="/category/<%= c.slug %>" class="cat-pill"><%= c.name %></a><% }) %></section><section class="banners-grid"><% banners.forEach(b => { %><a href="<%= b.link_url %>" class="banner-card"><img src="<%= b.image_url %>" alt="<%= b.title %>"><div class="banner-title"><%= b.title %></div></a><% }) %></section><section class="section-head" id="flash-sale"><h2><%= cms?.section_flash_title %></h2></section><div class="products-grid"><% flashSales.forEach(item => { %><div class="product-card flash"><img src="<%= item.image_url %>" alt=""><div class="product-info"><h3><%= item.name %></h3><div class="old-price"><%= money(item.original_price) %></div><div class="price"><%= money(item.sale_price) %></div><form method="post" action="/cart/add/<%= item.product_id %>"><button class="btn primary full">Mua ngay</button></form></div></div><% }) %></div><section class="section-head"><h2><%= cms?.section_combo_title %></h2></section><div class="products-grid"><% combos.forEach(p => { %><div class="product-card"><img src="<%= p.image_url %>" alt=""><div class="product-info"><h3><%= p.name %></h3><div class="muted"><%= p.short_desc %></div><div class="price"><%= money(p.sale_price || p.price) %></div><form method="post" action="/cart/add/<%= p.id %>"><button class="btn primary full">Thêm vào giỏ</button></form></div></div><% }) %></div><section class="section-head"><h2><%= cms?.section_featured_title %></h2></section><div class="products-grid"><% featured.forEach(p => { %><div class="product-card"><img src="<%= p.image_url %>" alt=""><div class="product-info"><h3><%= p.name %></h3><div class="muted"><%= p.storage_note %></div><div class="price"><%= money(p.sale_price || p.price) %></div><form method="post" action="/cart/add/<%= p.id %>"><button class="btn primary full">Thêm vào giỏ</button></form></div></div><% }) %></div><%- include('partials/footer') %>
