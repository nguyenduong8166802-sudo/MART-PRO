<%- include('partials/header') %>
<h2>Flash Sale</h2>
<div class="panel">
  <form method="post" action="/admin/flash-sales" class="form-grid">
    <select name="product_id"><% products.forEach(p => { %><option value="<%= p.id %>"><%= p.name %></option><% }) %></select>
    <input name="sale_price" placeholder="Giá sale">
    <input name="start_at" placeholder="2026-04-05 10:00:00">
    <input name="end_at" placeholder="2026-04-05 22:00:00">
    <label><input type="checkbox" name="is_active" checked> Bật</label>
    <button class="btn primary">Thêm Flash Sale</button>
  </form>
</div>
<div class="table-wrap">
<table>
<tr><th>ID</th><th>Sản phẩm</th><th>Giá sale</th></tr>
<% flashSales.forEach(f => { %>
<tr><td><%= f.id %></td><td><%= f.name %></td><td><%= Number(f.sale_price).toLocaleString('vi-VN') %>đ</td></tr>
<% }) %>
</table>
</div>
<%- include('partials/footer') %>
