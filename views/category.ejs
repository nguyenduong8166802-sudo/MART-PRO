<%- include('partials/header') %>
<section class="section-head"><h2><%= category.name %></h2></section>
<div class="products-grid">
  <% products.forEach(p => { %>
    <div class="product-card">
      <img src="<%= p.image_url %>" alt="">
      <div class="product-info">
        <h3><%= p.name %></h3>
        <div class="muted"><%= p.short_desc %></div>
        <div class="price"><%= Number(p.sale_price || p.price).toLocaleString('vi-VN') %>đ</div>
        <form method="post" action="/cart/add/<%= p.id %>"><button class="btn primary full">Thêm vào giỏ</button></form>
      </div>
    </div>
  <% }) %>
</div>
<%- include('partials/footer') %>
