<%- include('partials/header') %><h2>Duyệt sản phẩm seller</h2><div class="table-wrap"><table><tr><th>ID</th><th>Seller</th><th>Sản phẩm</th><th>Giá</th><th>Tồn</th><th>Trạng thái</th><th>Hành động</th></tr><% products.forEach(p => { %><tr><td><%= p.id %></td><td><%= p.seller_name || '' %></td><td><strong><%= p.name %></strong><div class="muted"><%= p.short_desc || '' %></div><div class="muted"><%= p.rejection_note || '' %></div></td><td><%= money(p.sale_price || p.price) %></td><td><%= p.stock %></td><td><%= p.approval_status %></td><td><form method="post" action="/admin/seller-approvals/<%= p.id %>/approve" style="margin-bottom:6px;"><button class="btn primary small">Duyệt</button></form><form method="post" action="/admin/seller-approvals/<%= p.id %>/hide" style="margin-bottom:6px;"><button class="btn secondary small">Ẩn</button></form><form method="post" action="/admin/seller-approvals/<%= p.id %>/reject"><input name="rejection_note" placeholder="Lý do từ chối" style="margin-bottom:6px;width:160px;padding:8px;border:1px solid #ececec;border-radius:8px;"><button class="btn danger small">Từ chối</button></form></td></tr><% }) %></table></div><%- include('partials/footer') %>
